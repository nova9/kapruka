# Copy this file to .env.local and fill in your values

# Required: Your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: OpenAI API key (used for embeddings / fallback models)
# OPENAI_API_KEY=sk-proj-...

# Optional: enable debug UI in MessageBubble (default: false)
# NEXT_PUBLIC_DEBUG=true
